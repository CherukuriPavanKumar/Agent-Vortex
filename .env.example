# LLM
OPENROUTER_API_KEY=your_openrouter_api_key_here

# PostgreSQL
# The hostname 'postgres' matches the docker-compose service name.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agent_vortex

# WhatsApp MCP
# The hostname 'whatsapp-mcp' matches the docker-compose service name.
WHATSAPP_MCP_URL=http://whatsapp-mcp:8765/mcp

# Bearer token required when the WhatsApp MCP runs in Docker with --allow-remote.
# The agent uses this to authenticate MCP tool calls.
# The healthcheck also uses it to hit /pair.
# Generate a strong secret: openssl rand -hex 32
# This must match the WHATSAPP_MCP_TOKEN set in the WhatsApp MCP service.
WHATSAPP_MCP_TOKEN=changeme-set-in-dotenv